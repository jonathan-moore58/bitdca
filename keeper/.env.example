# BitDCA Keeper Bot — Environment Variables
# Copy this file to .env and fill in the values.

# REQUIRED: Keeper wallet mnemonic (12 words) — DO NOT commit real mnemonics!
KEEPER_MNEMONIC=

# REQUIRED: DCAVault contract address (set after deployment)
DCA_VAULT_ADDRESS=

# OPNet RPC endpoint
RPC_URL=https://testnet.opnet.org

# Network: regtest | testnet | mainnet
NETWORK=testnet

# MotoSwap router address (hex)
ROUTER_ADDRESS=0xa02aa5ca4c307107484d5fb690d811df1cf526f8de204d24528653dcae369a0f

# NativeSwap contract address (for BTC->Token DCA, optional)
NATIVE_SWAP_ADDRESS=

# NativeSwap reserve activation delay in blocks (optional, default: 0)
RESERVE_ACTIVATION_DELAY=0

# Poll interval in milliseconds (min: 5000, default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# Slippage tolerance in percent (1-50, default: 5)
SLIPPAGE_PERCENT=5

# Max satoshis to spend per transaction (default: 50000)
MAX_SATS_PER_TX=50000

# Fee rate in sat/vB (default: 10)
FEE_RATE=10
