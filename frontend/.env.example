# BitDCA Frontend — Environment Variables
# Copy this file to .env and fill in the values.
# All variables must be prefixed with VITE_ for Vite to expose them.

# OPNet RPC endpoint
VITE_RPC_URL=https://testnet.opnet.org

# DCAVault contract address (bech32m format, e.g. opt1s...)
VITE_DCA_VAULT_ADDRESS=

# DCAVault contract public key (32-byte hex, 0x-prefixed)
VITE_DCA_VAULT_ADDRESS_HEX=

# MotoSwap router address (hex)
VITE_MOTOSWAP_ROUTER=0xa02aa5ca4c307107484d5fb690d811df1cf526f8de204d24528653dcae369a0f

# NativeSwap contract address (hex, optional — for BTC->Token quotes)
VITE_NATIVE_SWAP_ADDRESS=

# Keeper BTC deposit address (for BTC->Token DCA — users send BTC here)
VITE_KEEPER_BTC_ADDRESS=
